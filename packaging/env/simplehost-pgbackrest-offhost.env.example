# Optional off-host pgBackRest repository mirror.
#
# Example:
# SIMPLEHOST_PGBACKREST_OFFHOST_TARGET=root@backup.example.net:/srv/backups/offhost/vps-prd/pgbackrest

SIMPLEHOST_PGBACKREST_REPO=/srv/backups/pgbackrest
SIMPLEHOST_PGBACKREST_OFFHOST_TARGET=
SIMPLEHOST_PGBACKREST_OFFHOST_SSH_OPTS="-o BatchMode=yes -o StrictHostKeyChecking=accept-new"
